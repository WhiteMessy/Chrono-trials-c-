@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Nav
@inject AuthenticationStateProvider Auth
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@using Microsoft.EntityFrameworkCore

<div class="page-wrapper">
    <nav class="nav">
        <a href="/" class="nav-logo glitch">CHRONO<span>TRIALS</span></a>

        <a href="/" class="nav-link @(IsActive("/") ? "active" : "")">Home</a>
        <a href="/game" class="nav-link @(IsActive("/game") ? "active" : "")">Spelen</a>
        <a href="/leaderboard" class="nav-link @(IsActive("/leaderboard") ? "active" : "")">Leaderboard</a>
        @if (_showBuyLink)
        {
            <a href="/kopen" class="nav-link @(IsActive("/kopen") ? "active" : "")">Kopen</a>
        }

        <AuthorizeView>
            <Authorized>
                <a href="/account" class="nav-user" style="text-decoration:none;cursor:pointer;">@context.User.Identity?.Name</a>
                <form action="/auth/logout" method="post" style="display:inline">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-outline btn-sm" style="border-color:rgba(240,74,74,0.4);color:#f08080;">Uitloggen</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="btn btn-outline btn-sm">Inloggen</a>
                <a href="/registreren" class="btn btn-gold btn-sm">Registreren</a>
            </NotAuthorized>
        </AuthorizeView>
    </nav>

    <main>
        @Body
    </main>

    <footer class="footer">
        CHRONO TRIALS &nbsp;·&nbsp; AMURA'S WATER WORLD &nbsp;·&nbsp; 2025
    </footer>
</div>

@code {
    bool _showBuyLink = true;

    protected override async Task OnInitializedAsync()
    {
        await RefreshBuyLinkAsync();
        Nav.LocationChanged += HandleLocationChanged;
    }

    async Task RefreshBuyLinkAsync()
    {
        var auth = await Auth.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!int.TryParse(userId, out var parsedUserId))
        {
            _showBuyLink = true;
            StateHasChanged();
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        _showBuyLink = !await db.Users.AsNoTracking().AnyAsync(u => u.Id == parsedUserId && u.Purchased);

        StateHasChanged();
    }

    private async void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        await InvokeAsync(RefreshBuyLinkAsync);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }

    bool IsActive(string href)
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        return href == "/" ? current == "" : current.StartsWith(href.TrimStart('/'));
    }
}
