@page "/registreren"

<PageTitle>Registreren — Chrono Trials</PageTitle>

<div class="container-sm" style="padding-top:6rem;">
    <div class="card">
        <p class="card-title">Account aanmaken</p>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-error">@Error</div>
        }

        <form method="post" action="/auth/register">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="form-group">
                <label class="form-label">Gebruikersnaam</label>
                <input class="form-input" name="username" placeholder="JouwNaam" maxlength="20" autocomplete="username" />
            </div>

            <div class="form-group">
                <label class="form-label">E-mailadres</label>
                <input class="form-input" type="email" name="email" placeholder="jij@email.com" autocomplete="email" />
            </div>

            <div class="form-group">
                <label class="form-label">Wachtwoord (minimaal 6 tekens)</label>
                <input class="form-input" type="password" name="password" placeholder="••••••" autocomplete="new-password" />
            </div>

            <div class="form-group">
                <label class="form-label">Wachtwoord herhalen</label>
                <input class="form-input" type="password" name="passwordConfirm" placeholder="••••••" autocomplete="new-password" />
            </div>

            <button class="btn btn-gold" style="width:100%;justify-content:center;" type="submit">
                Account aanmaken
            </button>
        </form>

        <p style="text-align:center;margin-top:1.5rem;font-size:14px;color:var(--text-dim);">
            Al een account?
            <a href="/login">Inloggen</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
}
