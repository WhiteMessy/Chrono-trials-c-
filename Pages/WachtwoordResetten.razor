@page "/wachtwoord-resetten"

<PageTitle>Nieuw wachtwoord — Chrono Trials</PageTitle>

<div class="container-sm" style="padding-top:6rem;">
    <div class="card">
        <p class="card-title">Nieuw wachtwoord instellen</p>

        @if (string.IsNullOrEmpty(Token))
        {
            <div class="alert alert-error">
                Deze link is ongeldig. Vraag een nieuwe wachtwoord-reset aan.
            </div>

            <p style="text-align:center;margin-top:1.5rem;font-size:14px;color:var(--text-dim);">
                <a href="/wachtwoord-vergeten">Wachtwoord vergeten</a>
            </p>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Error))
            {
                <div class="alert alert-error">@Error</div>
            }

            <form method="post" action="/auth/reset-password">
                <input type="hidden" name="token" value="@Token" />

                <div class="form-group">
                    <label class="form-label">Nieuw wachtwoord (minimaal 6 tekens)</label>
                    <input class="form-input" type="password" name="password" placeholder="••••••" autocomplete="new-password" />
                </div>

                <div class="form-group">
                    <label class="form-label">Nieuw wachtwoord herhalen</label>
                    <input class="form-input" type="password" name="passwordConfirm" placeholder="••••••" autocomplete="new-password" />
                </div>

                <button class="btn btn-gold" style="width:100%;justify-content:center;" type="submit">
                    Wachtwoord opnieuw instellen
                </button>
            </form>

            <p style="text-align:center;margin-top:1.5rem;font-size:14px;color:var(--text-dim);">
                <a href="/login">Terug naar inloggen</a>
            </p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }
}