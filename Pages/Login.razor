@page "/login"
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Nav

<PageTitle>Inloggen — Chrono Trials</PageTitle>

<div class="container-sm" style="padding-top:6rem;">
    <div class="card">
        <p class="card-title">Inloggen</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-error">@_error</div>
        }

        <div class="form-group">
            <label class="form-label">Gebruikersnaam</label>
            <input class="form-input" @bind="_username" placeholder="JouwNaam" />
        </div>

        <div class="form-group">
            <label class="form-label">Wachtwoord</label>
            <input class="form-input" type="password" @bind="_password" placeholder="••••••"
                   @onkeydown="@(async e => { if (e.Key == "Enter") await DoLogin(); })" />
        </div>

        <button class="btn btn-gold" style="width:100%;justify-content:center;"
                @onclick="DoLogin" disabled="@_loading">
            @(_loading ? "Bezig..." : "Inloggen")
        </button>

        <p style="text-align:center;margin-top:1.5rem;font-size:14px;color:var(--text-dim);">
            Nog geen account?
            <a href="/registreren">Registreer hier</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] string? ReturnUrl { get; set; }

    string _username = "", _password = "", _error = "";
    bool _loading = false;

    async Task DoLogin()
    {
        _loading = true;
        _error = "";

        var result = await SignInManager.PasswordSignInAsync(_username, _password, true, false);

        if (result.Succeeded)
            Nav.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
        else
        {
            _error = "Gebruikersnaam of wachtwoord onjuist.";
            _loading = false;
        }
    }
}
