@page "/login"

<PageTitle>Inloggen — Chrono Trials</PageTitle>

<div class="container-sm" style="padding-top:6rem;">
    <div class="card">
        <p class="card-title">Inloggen</p>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-error">@Error</div>
        }

        @if (Reset == "1")
        {
            <div class="alert alert-success">Je wachtwoord is gewijzigd. Je kan nu inloggen.</div>
        }

        <form method="post" action="/auth/login">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="form-group">
                <label class="form-label">Gebruikersnaam</label>
                <input class="form-input" name="username" placeholder="JouwNaam" autocomplete="username" />
            </div>

            <div class="form-group">
                <label class="form-label">Wachtwoord</label>
                <input class="form-input" type="password" name="password" placeholder="••••••" autocomplete="current-password" />
                <p style="text-align:right;margin-top:0.5rem;">
                    <a href="/wachtwoord-vergeten" style="font-size:13px;color:var(--text-dim);">Wachtwoord vergeten?</a>
                </p>
            </div>

            <button class="btn btn-gold" style="width:100%;justify-content:center;" type="submit">
                Inloggen
            </button>
        </form>

        <p style="text-align:center;margin-top:1.5rem;font-size:14px;color:var(--text-dim);">
            Nog geen account?
            <a href="/registreren">Registreer hier</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Reset { get; set; }
}